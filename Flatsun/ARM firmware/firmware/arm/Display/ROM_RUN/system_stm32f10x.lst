 239:../Libraries//CMSIS/CM3/DeviceSupport/ST/STM32F10x//system_stm32f10x.c ****   RCC->CIR = 0x00FF0000;
 240:../Libraries//CMSIS/CM3/DeviceSupport/ST/STM32F10x//system_stm32f10x.c **** 
