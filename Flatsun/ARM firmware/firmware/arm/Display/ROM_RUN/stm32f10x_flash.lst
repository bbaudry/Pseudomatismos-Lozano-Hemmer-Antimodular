 920:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** /**
 921:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @brief  Programs a half word at a specified Option Byte Data address.
 922:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @note   This function can be used for all STM32F10x devices.
 923:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @param  Address: specifies the address to be programmed.
 924:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *   This parameter can be 0x1FFFF804 or 0x1FFFF806. 
 925:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @param  Data: specifies the data to be programmed.
 926:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @retval FLASH Status: The returned value can be: FLASH_ERROR_PG,
 927:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *         FLASH_ERROR_WRP, FLASH_COMPLETE or FLASH_TIMEOUT. 
 928:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   */
 929:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** FLASH_Status FLASH_ProgramOptionByteData(uint32_t Address, uint8_t Data)
 930:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** {
 931:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   FLASH_Status status = FLASH_COMPLETE;
 932:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Check the parameters */
 933:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   assert_param(IS_OB_DATA_ADDRESS(Address));
 934:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   status = FLASH_WaitForLastOperation(ProgramTimeout);
 935:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 936:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   if(status == FLASH_COMPLETE)
 937:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   {
 938:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Authorize the small information block programming */
 939:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->OPTKEYR = FLASH_KEY1;
 940:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->OPTKEYR = FLASH_KEY2;
 941:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Enables the Option Bytes Programming operation */
 942:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->CR |= CR_OPTPG_Set; 
 943:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     *(__IO uint16_t*)Address = Data;
 944:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     
 945:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Wait for last operation to be completed */
 946:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     status = FLASH_WaitForLastOperation(ProgramTimeout);
 947:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     if(status != FLASH_TIMEOUT)
 948:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     {
 949:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* if the program operation is completed, disable the OPTPG Bit */
 950:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->CR &= CR_OPTPG_Reset;
 951:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     }
 952:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   }
 953:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Return the Option Byte Data Program Status */
 954:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   return status;
 955:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** }
 956:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 957:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** /**
 958:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @brief  Write protects the desired pages
 959:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @note   This function can be used for all STM32F10x devices.
 960:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @param  FLASH_Pages: specifies the address of the pages to be write protected.
 961:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *   This parameter can be:
 962:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *     @arg For @b STM32_Low-density_devices: value between FLASH_WRProt_Pages0to3 and FLASH_WRPro
 963:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *     @arg For @b STM32_Medium-density_devices: value between FLASH_WRProt_Pages0to3
 964:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *       and FLASH_WRProt_Pages124to127
 965:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *     @arg For @b STM32_High-density_devices: value between FLASH_WRProt_Pages0to1 and
 966:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *       FLASH_WRProt_Pages60to61 or FLASH_WRProt_Pages62to255
 967:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *     @arg For @b STM32_Connectivity_line_devices: value between FLASH_WRProt_Pages0to1 and
 968:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *       FLASH_WRProt_Pages60to61 or FLASH_WRProt_Pages62to127    
 969:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *     @arg For @b STM32_XL-density_devices: value between FLASH_WRProt_Pages0to1 and
 970:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *       FLASH_WRProt_Pages60to61 or FLASH_WRProt_Pages62to511
 971:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *     @arg FLASH_WRProt_AllPages
 972:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @retval FLASH Status: The returned value can be: FLASH_ERROR_PG,
 973:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *         FLASH_ERROR_WRP, FLASH_COMPLETE or FLASH_TIMEOUT.
 974:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   */
 975:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** FLASH_Status FLASH_EnableWriteProtection(uint32_t FLASH_Pages)
 976:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** {
 977:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   uint16_t WRP0_Data = 0xFFFF, WRP1_Data = 0xFFFF, WRP2_Data = 0xFFFF, WRP3_Data = 0xFFFF;
 978:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   
 979:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   FLASH_Status status = FLASH_COMPLETE;
 980:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   
 981:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Check the parameters */
 982:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   assert_param(IS_FLASH_WRPROT_PAGE(FLASH_Pages));
 983:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   
 984:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   FLASH_Pages = (uint32_t)(~FLASH_Pages);
 985:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   WRP0_Data = (uint16_t)(FLASH_Pages & WRP0_Mask);
 986:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   WRP1_Data = (uint16_t)((FLASH_Pages & WRP1_Mask) >> 8);
 987:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   WRP2_Data = (uint16_t)((FLASH_Pages & WRP2_Mask) >> 16);
 988:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   WRP3_Data = (uint16_t)((FLASH_Pages & WRP3_Mask) >> 24);
 989:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   
 990:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Wait for last operation to be completed */
 991:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   status = FLASH_WaitForLastOperation(ProgramTimeout);
 992:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   
 993:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   if(status == FLASH_COMPLETE)
 994:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   {
 995:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Authorizes the small information block programming */
 996:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->OPTKEYR = FLASH_KEY1;
 997:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->OPTKEYR = FLASH_KEY2;
 998:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->CR |= CR_OPTPG_Set;
 999:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     if(WRP0_Data != 0xFF)
1000:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     {
1001:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       OB->WRP0 = WRP0_Data;
1002:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       
1003:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* Wait for last operation to be completed */
1004:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       status = FLASH_WaitForLastOperation(ProgramTimeout);
1005:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     }
1006:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     if((status == FLASH_COMPLETE) && (WRP1_Data != 0xFF))
1007:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     {
1008:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       OB->WRP1 = WRP1_Data;
1009:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       
1010:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* Wait for last operation to be completed */
1011:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       status = FLASH_WaitForLastOperation(ProgramTimeout);
1012:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     }
1013:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     if((status == FLASH_COMPLETE) && (WRP2_Data != 0xFF))
1014:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     {
1015:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       OB->WRP2 = WRP2_Data;
1016:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       
1017:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* Wait for last operation to be completed */
1018:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       status = FLASH_WaitForLastOperation(ProgramTimeout);
1019:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     }
1020:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     
1021:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     if((status == FLASH_COMPLETE)&& (WRP3_Data != 0xFF))
1022:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     {
1023:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       OB->WRP3 = WRP3_Data;
1024:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****      
1025:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* Wait for last operation to be completed */
1026:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       status = FLASH_WaitForLastOperation(ProgramTimeout);
1027:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     }
1028:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****           
1029:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     if(status != FLASH_TIMEOUT)
1030:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     {
1031:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* if the program operation is completed, disable the OPTPG Bit */
1032:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->CR &= CR_OPTPG_Reset;
1033:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     }
1034:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   } 
1035:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Return the write protection operation Status */
1036:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   return status;       
1037:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** }
1038:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
1039:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** /**
1040:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @brief  Enables or disables the read out protection.
1041:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @note   If the user has already programmed the other option bytes before calling 
1042:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *   this function, he must re-program them since this function erases all option bytes.
1043:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @note   This function can be used for all STM32F10x devices.
1044:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @param  Newstate: new state of the ReadOut Protection.
1045:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *   This parameter can be: ENABLE or DISABLE.
1046:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @retval FLASH Status: The returned value can be: FLASH_ERROR_PG,
1047:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *         FLASH_ERROR_WRP, FLASH_COMPLETE or FLASH_TIMEOUT.
1048:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   */
1049:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** FLASH_Status FLASH_ReadOutProtection(FunctionalState NewState)
1050:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** {
1051:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   FLASH_Status status = FLASH_COMPLETE;
1052:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Check the parameters */
1053:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   assert_param(IS_FUNCTIONAL_STATE(NewState));
1054:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   status = FLASH_WaitForLastOperation(EraseTimeout);
1055:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   if(status == FLASH_COMPLETE)
1056:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   {
1057:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Authorizes the small information block programming */
1058:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->OPTKEYR = FLASH_KEY1;
1059:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->OPTKEYR = FLASH_KEY2;
1060:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->CR |= CR_OPTER_Set;
1061:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->CR |= CR_STRT_Set;
1062:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Wait for last operation to be completed */
1063:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     status = FLASH_WaitForLastOperation(EraseTimeout);
1064:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     if(status == FLASH_COMPLETE)
1065:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     {
1066:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* if the erase operation is completed, disable the OPTER Bit */
1067:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->CR &= CR_OPTER_Reset;
1068:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* Enable the Option Bytes Programming operation */
1069:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->CR |= CR_OPTPG_Set; 
1070:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       if(NewState != DISABLE)
1071:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       {
1072:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****         OB->RDP = 0x00;
1073:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       }
1074:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       else
1075:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       {
1076:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****         OB->RDP = RDP_Key;  
1077:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       }
1078:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* Wait for last operation to be completed */
1079:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       status = FLASH_WaitForLastOperation(EraseTimeout); 
1080:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     
1081:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       if(status != FLASH_TIMEOUT)
1082:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       {
1083:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****         /* if the program operation is completed, disable the OPTPG Bit */
1084:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****         FLASH->CR &= CR_OPTPG_Reset;
1085:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       }
1086:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     }
1087:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     else 
1088:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     {
1089:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       if(status != FLASH_TIMEOUT)
1090:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       {
1091:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****         /* Disable the OPTER Bit */
1092:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****         FLASH->CR &= CR_OPTER_Reset;
1093:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       }
1094:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     }
1095:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   }
1096:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Return the protection operation Status */
1097:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   return status;       
1098:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** }
1099:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
1100:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** /**
1101:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @brief  Programs the FLASH User Option Byte: IWDG_SW / RST_STOP / RST_STDBY.
1102:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @note   This function can be used for all STM32F10x devices.
1103:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @param  OB_IWDG: Selects the IWDG mode
1104:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *   This parameter can be one of the following values:
1105:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *     @arg OB_IWDG_SW: Software IWDG selected
1106:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *     @arg OB_IWDG_HW: Hardware IWDG selected
1107:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @param  OB_STOP: Reset event when entering STOP mode.
1108:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *   This parameter can be one of the following values:
1109:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *     @arg OB_STOP_NoRST: No reset generated when entering in STOP
1110:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *     @arg OB_STOP_RST: Reset generated when entering in STOP
1111:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @param  OB_STDBY: Reset event when entering Standby mode.
1112:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *   This parameter can be one of the following values:
1113:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *     @arg OB_STDBY_NoRST: No reset generated when entering in STANDBY
1114:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *     @arg OB_STDBY_RST: Reset generated when entering in STANDBY
1115:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @retval FLASH Status: The returned value can be: FLASH_ERROR_PG, 
1116:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *         FLASH_ERROR_WRP, FLASH_COMPLETE or FLASH_TIMEOUT.
1117:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   */
1118:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** FLASH_Status FLASH_UserOptionByteConfig(uint16_t OB_IWDG, uint16_t OB_STOP, uint16_t OB_STDBY)
1119:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** {
1120:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   FLASH_Status status = FLASH_COMPLETE; 
1121:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
1122:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Check the parameters */
1123:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   assert_param(IS_OB_IWDG_SOURCE(OB_IWDG));
1124:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   assert_param(IS_OB_STOP_SOURCE(OB_STOP));
1125:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   assert_param(IS_OB_STDBY_SOURCE(OB_STDBY));
1126:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
1127:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Authorize the small information block programming */
1128:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   FLASH->OPTKEYR = FLASH_KEY1;
1129:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   FLASH->OPTKEYR = FLASH_KEY2;
1130:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   
1131:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Wait for last operation to be completed */
1132:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   status = FLASH_WaitForLastOperation(ProgramTimeout);
1133:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   
1134:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   if(status == FLASH_COMPLETE)
1135:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   {  
1136:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Enable the Option Bytes Programming operation */
1137:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->CR |= CR_OPTPG_Set; 
1138:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****            
1139:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     OB->USER = OB_IWDG | (uint16_t)(OB_STOP | (uint16_t)(OB_STDBY | ((uint16_t)0xF8))); 
1140:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   
1141:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Wait for last operation to be completed */
1142:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     status = FLASH_WaitForLastOperation(ProgramTimeout);
1143:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     if(status != FLASH_TIMEOUT)
1144:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     {
1145:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* if the program operation is completed, disable the OPTPG Bit */
1146:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->CR &= CR_OPTPG_Reset;
1147:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     }
1148:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   }    
1149:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Return the Option Byte program Status */
1150:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   return status;
1151:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** }
