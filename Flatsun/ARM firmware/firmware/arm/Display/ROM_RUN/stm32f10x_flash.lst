 870:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     if(status == FLASH_COMPLETE)
 871:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     {
 872:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* if the previous operation is completed, proceed to program the new data */
 873:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->CR |= CR_PG_Set;
 874:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   
 875:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       *(__IO uint16_t*)Address = Data;
 876:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* Wait for last operation to be completed */
 877:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       status = FLASH_WaitForLastBank1Operation(ProgramTimeout);
 878:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 879:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* Disable the PG Bit */
 880:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->CR &= CR_PG_Reset;
 881:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     }
 882:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   }
 883:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   else
 884:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   {
 885:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     if(status == FLASH_COMPLETE)
 886:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     {
 887:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* if the previous operation is completed, proceed to program the new data */
 888:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->CR2 |= CR_PG_Set;
 889:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   
 890:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       *(__IO uint16_t*)Address = Data;
 891:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* Wait for last operation to be completed */
 892:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       status = FLASH_WaitForLastBank2Operation(ProgramTimeout);
 893:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 894:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* Disable the PG Bit */
 895:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->CR2 &= CR_PG_Reset;
 896:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     }
 897:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   }
 898:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** #else
 899:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Wait for last operation to be completed */
 900:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   status = FLASH_WaitForLastOperation(ProgramTimeout);
 901:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   
 902:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   if(status == FLASH_COMPLETE)
 903:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   {
 904:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* if the previous operation is completed, proceed to program the new data */
 905:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->CR |= CR_PG_Set;
 906:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   
 907:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     *(__IO uint16_t*)Address = Data;
 908:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Wait for last operation to be completed */
 909:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     status = FLASH_WaitForLastOperation(ProgramTimeout);
 910:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     
 911:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Disable the PG Bit */
 912:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->CR &= CR_PG_Reset;
 913:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   } 
 914:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** #endif  /* STM32F10X_XL */
 915:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   
 916:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Return the Program Status */
 917:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   return status;
 918:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** }
