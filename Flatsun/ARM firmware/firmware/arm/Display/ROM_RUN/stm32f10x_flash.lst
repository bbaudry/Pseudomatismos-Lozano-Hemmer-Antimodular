 412:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** /**
 413:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @brief  Erases a specified FLASH page.
 414:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @note   This function can be used for all STM32F10x devices.
 415:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @param  Page_Address: The page address to be erased.
 416:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @retval FLASH Status: The returned value can be: FLASH_BUSY, FLASH_ERROR_PG,
 417:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *         FLASH_ERROR_WRP, FLASH_COMPLETE or FLASH_TIMEOUT.
 418:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   */
 419:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** FLASH_Status FLASH_ErasePage(uint32_t Page_Address)
 420:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** {
 421:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   FLASH_Status status = FLASH_COMPLETE;
 422:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Check the parameters */
 423:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   assert_param(IS_FLASH_ADDRESS(Page_Address));
 424:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 425:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** #ifdef STM32F10X_XL
 426:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   if(Page_Address < FLASH_BANK1_END_ADDRESS)  
 427:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   {
 428:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Wait for last operation to be completed */
 429:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     status = FLASH_WaitForLastBank1Operation(EraseTimeout);
 430:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     if(status == FLASH_COMPLETE)
 431:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     { 
 432:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* if the previous operation is completed, proceed to erase the page */
 433:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->CR|= CR_PER_Set;
 434:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->AR = Page_Address; 
 435:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->CR|= CR_STRT_Set;
 436:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     
 437:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* Wait for last operation to be completed */
 438:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       status = FLASH_WaitForLastBank1Operation(EraseTimeout);
 439:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 440:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* Disable the PER Bit */
 441:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->CR &= CR_PER_Reset;
 442:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     }
 443:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   }
 444:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   else
 445:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   {
 446:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Wait for last operation to be completed */
 447:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     status = FLASH_WaitForLastBank2Operation(EraseTimeout);
 448:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     if(status == FLASH_COMPLETE)
 449:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     { 
 450:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* if the previous operation is completed, proceed to erase the page */
 451:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->CR2|= CR_PER_Set;
 452:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->AR2 = Page_Address; 
 453:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->CR2|= CR_STRT_Set;
 454:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     
 455:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* Wait for last operation to be completed */
 456:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       status = FLASH_WaitForLastBank2Operation(EraseTimeout);
 457:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       
 458:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* Disable the PER Bit */
 459:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->CR2 &= CR_PER_Reset;
 460:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     }
 461:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   }
 462:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** #else
 463:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Wait for last operation to be completed */
 464:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   status = FLASH_WaitForLastOperation(EraseTimeout);
 465:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   
 466:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   if(status == FLASH_COMPLETE)
 467:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   { 
 468:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* if the previous operation is completed, proceed to erase the page */
 469:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->CR|= CR_PER_Set;
 470:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->AR = Page_Address; 
 471:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->CR|= CR_STRT_Set;
 472:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     
 473:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Wait for last operation to be completed */
 474:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     status = FLASH_WaitForLastOperation(EraseTimeout);
 475:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     
 476:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Disable the PER Bit */
 477:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->CR &= CR_PER_Reset;
 478:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   }
 479:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** #endif /* STM32F10X_XL */
 480:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 481:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Return the Erase Status */
 482:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   return status;
 483:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** }
 484:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 485:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** /**
 486:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @brief  Erases all FLASH pages.
 487:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @note   This function can be used for all STM32F10x devices.
 488:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @param  None
 489:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @retval FLASH Status: The returned value can be: FLASH_ERROR_PG,
 490:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *         FLASH_ERROR_WRP, FLASH_COMPLETE or FLASH_TIMEOUT.
 491:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   */
 492:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** FLASH_Status FLASH_EraseAllPages(void)
 493:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** {
 494:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   FLASH_Status status = FLASH_COMPLETE;
 495:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 496:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** #ifdef STM32F10X_XL
 497:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Wait for last operation to be completed */
 498:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   status = FLASH_WaitForLastBank1Operation(EraseTimeout);
 499:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   
 500:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   if(status == FLASH_COMPLETE)
 501:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   {
 502:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* if the previous operation is completed, proceed to erase all pages */
 503:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****      FLASH->CR |= CR_MER_Set;
 504:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****      FLASH->CR |= CR_STRT_Set;
 505:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     
 506:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Wait for last operation to be completed */
 507:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     status = FLASH_WaitForLastBank1Operation(EraseTimeout);
 508:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     
 509:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Disable the MER Bit */
 510:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->CR &= CR_MER_Reset;
 511:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   }    
 512:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   if(status == FLASH_COMPLETE)
 513:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   {
 514:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* if the previous operation is completed, proceed to erase all pages */
 515:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****      FLASH->CR2 |= CR_MER_Set;
 516:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****      FLASH->CR2 |= CR_STRT_Set;
 517:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     
 518:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Wait for last operation to be completed */
 519:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     status = FLASH_WaitForLastBank2Operation(EraseTimeout);
 520:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     
 521:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Disable the MER Bit */
 522:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->CR2 &= CR_MER_Reset;
 523:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   }
 524:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** #else
 525:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Wait for last operation to be completed */
 526:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   status = FLASH_WaitForLastOperation(EraseTimeout);
 527:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   if(status == FLASH_COMPLETE)
 528:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   {
 529:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* if the previous operation is completed, proceed to erase all pages */
 530:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****      FLASH->CR |= CR_MER_Set;
 531:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****      FLASH->CR |= CR_STRT_Set;
 532:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     
 533:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Wait for last operation to be completed */
 534:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     status = FLASH_WaitForLastOperation(EraseTimeout);
 535:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 536:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Disable the MER Bit */
 537:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->CR &= CR_MER_Reset;
 538:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   }
 539:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** #endif /* STM32F10X_XL */
 540:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 541:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Return the Erase Status */
 542:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   return status;
 543:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** }
 544:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 545:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** /**
 546:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @brief  Erases all Bank1 FLASH pages.
 547:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @note   This function can be used for all STM32F10x devices.
 548:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *         - For STM32F10X_XL devices this function erases all Bank1 pages.
 549:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *         - For all other devices it erases all Bank1 pages and it is equivalent 
 550:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *           to FLASH_EraseAllPages function.
 551:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @param  None
 552:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @retval FLASH Status: The returned value can be: FLASH_ERROR_PG,
 553:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *         FLASH_ERROR_WRP, FLASH_COMPLETE or FLASH_TIMEOUT.
 554:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   */
 555:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** FLASH_Status FLASH_EraseAllBank1Pages(void)
 556:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** {
 557:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   FLASH_Status status = FLASH_COMPLETE;
 558:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Wait for last operation to be completed */
 559:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   status = FLASH_WaitForLastBank1Operation(EraseTimeout);
 560:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   
 561:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   if(status == FLASH_COMPLETE)
 562:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   {
 563:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* if the previous operation is completed, proceed to erase all pages */
 564:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****      FLASH->CR |= CR_MER_Set;
 565:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****      FLASH->CR |= CR_STRT_Set;
 566:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     
 567:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Wait for last operation to be completed */
 568:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     status = FLASH_WaitForLastBank1Operation(EraseTimeout);
 569:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     
 570:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Disable the MER Bit */
 571:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->CR &= CR_MER_Reset;
 572:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   }    
 573:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Return the Erase Status */
 574:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   return status;
 575:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** }
 576:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 577:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** #ifdef STM32F10X_XL
 578:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** /**
 579:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @brief  Erases all Bank2 FLASH pages.
 580:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @note   This function can be used only for STM32F10x_XL density devices.
 581:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @param  None
 582:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @retval FLASH Status: The returned value can be: FLASH_ERROR_PG,
 583:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *         FLASH_ERROR_WRP, FLASH_COMPLETE or FLASH_TIMEOUT.
 584:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   */
 585:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** FLASH_Status FLASH_EraseAllBank2Pages(void)
 586:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** {
 587:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   FLASH_Status status = FLASH_COMPLETE;
 588:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Wait for last operation to be completed */
 589:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   status = FLASH_WaitForLastBank2Operation(EraseTimeout);
 590:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   
 591:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   if(status == FLASH_COMPLETE)
 592:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   {
 593:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* if the previous operation is completed, proceed to erase all pages */
 594:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****      FLASH->CR2 |= CR_MER_Set;
 595:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****      FLASH->CR2 |= CR_STRT_Set;
 596:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     
 597:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Wait for last operation to be completed */
 598:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     status = FLASH_WaitForLastBank2Operation(EraseTimeout);
 599:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 600:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Disable the MER Bit */
 601:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->CR2 &= CR_MER_Reset;
 602:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   }    
 603:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Return the Erase Status */
 604:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   return status;
 605:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** }
 606:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** #endif /* STM32F10X_XL */
 607:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 608:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** /**
 609:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @brief  Erases the FLASH option bytes.
 610:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @note   This functions erases all option bytes except the Read protection (RDP). 
 611:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @note   This function can be used for all STM32F10x devices.
 612:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @param  None
 613:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @retval FLASH Status: The returned value can be: FLASH_ERROR_PG,
 614:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   *         FLASH_ERROR_WRP, FLASH_COMPLETE or FLASH_TIMEOUT.
 615:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   */
 616:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** FLASH_Status FLASH_EraseOptionBytes(void)
 617:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** {
 618:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   uint16_t rdptmp = RDP_Key;
 619:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 620:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   FLASH_Status status = FLASH_COMPLETE;
 621:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 622:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Get the actual read protection Option Byte value */ 
 623:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   if(FLASH_GetReadOutProtectionStatus() != RESET)
 624:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   {
 625:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     rdptmp = 0x00;  
 626:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   }
 627:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 628:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Wait for last operation to be completed */
 629:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   status = FLASH_WaitForLastOperation(EraseTimeout);
 630:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   if(status == FLASH_COMPLETE)
 631:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   {
 632:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Authorize the small information block programming */
 633:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->OPTKEYR = FLASH_KEY1;
 634:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->OPTKEYR = FLASH_KEY2;
 635:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     
 636:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* if the previous operation is completed, proceed to erase the option bytes */
 637:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->CR |= CR_OPTER_Set;
 638:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     FLASH->CR |= CR_STRT_Set;
 639:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     /* Wait for last operation to be completed */
 640:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     status = FLASH_WaitForLastOperation(EraseTimeout);
 641:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     
 642:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     if(status == FLASH_COMPLETE)
 643:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     {
 644:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* if the erase operation is completed, disable the OPTER Bit */
 645:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->CR &= CR_OPTER_Reset;
 646:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****        
 647:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* Enable the Option Bytes Programming operation */
 648:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       FLASH->CR |= CR_OPTPG_Set;
 649:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* Restore the last read protection Option Byte value */
 650:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       OB->RDP = (uint16_t)rdptmp; 
 651:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       /* Wait for last operation to be completed */
 652:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       status = FLASH_WaitForLastOperation(ProgramTimeout);
 653:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****  
 654:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       if(status != FLASH_TIMEOUT)
 655:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       {
 656:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****         /* if the program operation is completed, disable the OPTPG Bit */
 657:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****         FLASH->CR &= CR_OPTPG_Reset;
 658:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       }
 659:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     }
 660:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     else
 661:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     {
 662:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       if (status != FLASH_TIMEOUT)
 663:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       {
 664:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****         /* Disable the OPTPG Bit */
 665:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****         FLASH->CR &= CR_OPTPG_Reset;
 666:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****       }
 667:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****     }  
 668:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   }
 669:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   /* Return the erase status */
 670:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   return status;
 671:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** }
 672:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** 
 673:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c **** /**
 674:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @brief  Programs a word at a specified address.
 675:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @note   This function can be used for all STM32F10x devices.
 676:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @param  Address: specifies the address to be programmed.
 677:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @param  Data: specifies the data to be programmed.
 678:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_flash.c ****   * @retval FLASH Status: The returned value can be: FLASH_ERROR_PG,
