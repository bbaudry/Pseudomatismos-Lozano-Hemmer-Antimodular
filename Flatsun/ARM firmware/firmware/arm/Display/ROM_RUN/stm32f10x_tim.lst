2481:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval Capture Compare 3 Register value.
2482:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
2483:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** uint16_t TIM_GetCapture3(TIM_TypeDef* TIMx)
2484:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
2485:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
2486:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST3_PERIPH(TIMx)); 
2487:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Get the Capture 3 Register value */
2488:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   return TIMx->CCR3;
2489:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
2490:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
