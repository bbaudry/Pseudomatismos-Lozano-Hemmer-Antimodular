 536:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccer = TIMx->CCER;
 537:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Get the TIMx CR2 register value */
 538:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpcr2 =  TIMx->CR2;
 539:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
 540:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Get the TIMx CCMR2 register value */
 541:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccmrx = TIMx->CCMR2;
 542:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     
 543:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Reset the Output Compare mode and Capture/Compare selection Bits */
 544:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccmrx &= (uint16_t)(~((uint16_t)TIM_CCMR2_OC4M));
 545:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccmrx &= (uint16_t)(~((uint16_t)TIM_CCMR2_CC4S));
 546:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
 547:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Select the Output Compare Mode */
 548:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccmrx |= (uint16_t)(TIM_OCInitStruct->TIM_OCMode << 8);
 549:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
 550:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Reset the Output Polarity level */
 551:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccer &= (uint16_t)(~((uint16_t)TIM_CCER_CC4P));
 552:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set the Output Compare Polarity */
 553:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccer |= (uint16_t)(TIM_OCInitStruct->TIM_OCPolarity << 12);
 554:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
 555:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set the Output State */
 556:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccer |= (uint16_t)(TIM_OCInitStruct->TIM_OutputState << 12);
 557:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     
 558:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if((TIMx == TIM1) || (TIMx == TIM8))
 559:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 560:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     assert_param(IS_TIM_OCIDLE_STATE(TIM_OCInitStruct->TIM_OCIdleState));
 561:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Reset the Output Compare IDLE State */
 562:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     tmpcr2 &= (uint16_t)(~((uint16_t)TIM_CR2_OIS4));
 563:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Set the Output Idle state */
 564:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     tmpcr2 |= (uint16_t)(TIM_OCInitStruct->TIM_OCIdleState << 6);
 565:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 566:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Write to TIMx CR2 */
 567:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CR2 = tmpcr2;
 568:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
 569:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Write to TIMx CCMR2 */  
 570:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CCMR2 = tmpccmrx;
 571:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 572:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set the Capture Compare Register value */
 573:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CCR4 = TIM_OCInitStruct->TIM_Pulse;
 574:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
 575:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Write to TIMx CCER */
 576:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CCER = tmpccer;
 577:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
 578:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 579:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
 580:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Initializes the TIM peripheral according to the specified
 581:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *         parameters in the TIM_ICInitStruct.
 582:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be  1 to 17 except 6 and 7 to select the TIM peripheral.
 583:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_ICInitStruct: pointer to a TIM_ICInitTypeDef structure
 584:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *         that contains the configuration information for the specified TIM peripheral.
 585:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
 586:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
 587:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_ICInit(TIM_TypeDef* TIMx, TIM_ICInitTypeDef* TIM_ICInitStruct)
 588:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
 589:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
 590:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_CHANNEL(TIM_ICInitStruct->TIM_Channel));  
 591:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_IC_SELECTION(TIM_ICInitStruct->TIM_ICSelection));
 592:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_IC_PRESCALER(TIM_ICInitStruct->TIM_ICPrescaler));
 593:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_IC_FILTER(TIM_ICInitStruct->TIM_ICFilter));
 594:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
 595:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if((TIMx == TIM1) || (TIMx == TIM8) || (TIMx == TIM2) || (TIMx == TIM3) ||
 596:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****      (TIMx == TIM4) ||(TIMx == TIM5))
 597:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 598:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     assert_param(IS_TIM_IC_POLARITY(TIM_ICInitStruct->TIM_ICPolarity));
 599:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 600:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else
 601:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 602:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     assert_param(IS_TIM_IC_POLARITY_LITE(TIM_ICInitStruct->TIM_ICPolarity));
 603:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 604:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if (TIM_ICInitStruct->TIM_Channel == TIM_Channel_1)
 605:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 606:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     assert_param(IS_TIM_LIST8_PERIPH(TIMx));
 607:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* TI1 Configuration */
 608:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TI1_Config(TIMx, TIM_ICInitStruct->TIM_ICPolarity,
 609:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****                TIM_ICInitStruct->TIM_ICSelection,
 610:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****                TIM_ICInitStruct->TIM_ICFilter);
 611:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Set the Input Capture Prescaler value */
 612:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIM_SetIC1Prescaler(TIMx, TIM_ICInitStruct->TIM_ICPrescaler);
 613:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 614:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else if (TIM_ICInitStruct->TIM_Channel == TIM_Channel_2)
 615:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 616:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     assert_param(IS_TIM_LIST6_PERIPH(TIMx));
 617:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* TI2 Configuration */
 618:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TI2_Config(TIMx, TIM_ICInitStruct->TIM_ICPolarity,
 619:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****                TIM_ICInitStruct->TIM_ICSelection,
 620:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****                TIM_ICInitStruct->TIM_ICFilter);
 621:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Set the Input Capture Prescaler value */
 622:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIM_SetIC2Prescaler(TIMx, TIM_ICInitStruct->TIM_ICPrescaler);
 623:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 624:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else if (TIM_ICInitStruct->TIM_Channel == TIM_Channel_3)
 625:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 626:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     assert_param(IS_TIM_LIST3_PERIPH(TIMx));
 627:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* TI3 Configuration */
 628:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TI3_Config(TIMx,  TIM_ICInitStruct->TIM_ICPolarity,
 629:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****                TIM_ICInitStruct->TIM_ICSelection,
 630:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****                TIM_ICInitStruct->TIM_ICFilter);
 631:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Set the Input Capture Prescaler value */
 632:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIM_SetIC3Prescaler(TIMx, TIM_ICInitStruct->TIM_ICPrescaler);
 633:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 634:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else
 635:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 636:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     assert_param(IS_TIM_LIST3_PERIPH(TIMx));
 637:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* TI4 Configuration */
 638:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TI4_Config(TIMx, TIM_ICInitStruct->TIM_ICPolarity,
 639:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****                TIM_ICInitStruct->TIM_ICSelection,
 640:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****                TIM_ICInitStruct->TIM_ICFilter);
 641:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Set the Input Capture Prescaler value */
 642:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIM_SetIC4Prescaler(TIMx, TIM_ICInitStruct->TIM_ICPrescaler);
 643:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 644:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
 645:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 646:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
 647:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Configures the TIM peripheral according to the specified
 648:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *         parameters in the TIM_ICInitStruct to measure an external PWM signal.
 649:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be  1, 2, 3, 4, 5, 8, 9, 12 or 15 to select the TIM peripheral.
 650:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_ICInitStruct: pointer to a TIM_ICInitTypeDef structure
 651:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *         that contains the configuration information for the specified TIM peripheral.
 652:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
 653:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
 654:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_PWMIConfig(TIM_TypeDef* TIMx, TIM_ICInitTypeDef* TIM_ICInitStruct)
 655:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
 656:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   uint16_t icoppositepolarity = TIM_ICPolarity_Rising;
 657:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   uint16_t icoppositeselection = TIM_ICSelection_DirectTI;
 658:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
 659:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST6_PERIPH(TIMx));
 660:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Select the Opposite Input Polarity */
 661:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if (TIM_ICInitStruct->TIM_ICPolarity == TIM_ICPolarity_Rising)
 662:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 663:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     icoppositepolarity = TIM_ICPolarity_Falling;
 664:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 665:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else
 666:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 667:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     icoppositepolarity = TIM_ICPolarity_Rising;
 668:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 669:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Select the Opposite Input */
 670:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if (TIM_ICInitStruct->TIM_ICSelection == TIM_ICSelection_DirectTI)
 671:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 672:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     icoppositeselection = TIM_ICSelection_IndirectTI;
 673:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 674:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else
 675:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 676:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     icoppositeselection = TIM_ICSelection_DirectTI;
 677:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 678:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if (TIM_ICInitStruct->TIM_Channel == TIM_Channel_1)
 679:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 680:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* TI1 Configuration */
 681:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TI1_Config(TIMx, TIM_ICInitStruct->TIM_ICPolarity, TIM_ICInitStruct->TIM_ICSelection,
 682:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****                TIM_ICInitStruct->TIM_ICFilter);
 683:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Set the Input Capture Prescaler value */
 684:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIM_SetIC1Prescaler(TIMx, TIM_ICInitStruct->TIM_ICPrescaler);
 685:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* TI2 Configuration */
 686:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TI2_Config(TIMx, icoppositepolarity, icoppositeselection, TIM_ICInitStruct->TIM_ICFilter);
 687:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Set the Input Capture Prescaler value */
 688:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIM_SetIC2Prescaler(TIMx, TIM_ICInitStruct->TIM_ICPrescaler);
 689:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 690:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else
 691:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   { 
 692:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* TI2 Configuration */
 693:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TI2_Config(TIMx, TIM_ICInitStruct->TIM_ICPolarity, TIM_ICInitStruct->TIM_ICSelection,
 694:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****                TIM_ICInitStruct->TIM_ICFilter);
 695:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Set the Input Capture Prescaler value */
 696:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIM_SetIC2Prescaler(TIMx, TIM_ICInitStruct->TIM_ICPrescaler);
 697:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* TI1 Configuration */
 698:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TI1_Config(TIMx, icoppositepolarity, icoppositeselection, TIM_ICInitStruct->TIM_ICFilter);
 699:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Set the Input Capture Prescaler value */
 700:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIM_SetIC1Prescaler(TIMx, TIM_ICInitStruct->TIM_ICPrescaler);
 701:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 702:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
 703:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 704:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
 705:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Configures the: Break feature, dead time, Lock level, the OSSI,
 706:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *         the OSSR State and the AOE(automatic output enable).
 707:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be  1 or 8 to select the TIM 
 708:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_BDTRInitStruct: pointer to a TIM_BDTRInitTypeDef structure that
 709:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *         contains the BDTR Register configuration  information for the TIM peripheral.
 710:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
 711:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
 712:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_BDTRConfig(TIM_TypeDef* TIMx, TIM_BDTRInitTypeDef *TIM_BDTRInitStruct)
 713:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
 714:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
 715:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST2_PERIPH(TIMx));
 716:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_OSSR_STATE(TIM_BDTRInitStruct->TIM_OSSRState));
 717:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_OSSI_STATE(TIM_BDTRInitStruct->TIM_OSSIState));
 718:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LOCK_LEVEL(TIM_BDTRInitStruct->TIM_LOCKLevel));
 719:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_BREAK_STATE(TIM_BDTRInitStruct->TIM_Break));
 720:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_BREAK_POLARITY(TIM_BDTRInitStruct->TIM_BreakPolarity));
 721:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_AUTOMATIC_OUTPUT_STATE(TIM_BDTRInitStruct->TIM_AutomaticOutput));
 722:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set the Lock level, the Break enable Bit and the Ploarity, the OSSR State,
 723:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****      the OSSI State, the dead time value and the Automatic Output Enable Bit */
 724:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->BDTR = (uint32_t)TIM_BDTRInitStruct->TIM_OSSRState | TIM_BDTRInitStruct->TIM_OSSIState |
 725:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****              TIM_BDTRInitStruct->TIM_LOCKLevel | TIM_BDTRInitStruct->TIM_DeadTime |
 726:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****              TIM_BDTRInitStruct->TIM_Break | TIM_BDTRInitStruct->TIM_BreakPolarity |
 727:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****              TIM_BDTRInitStruct->TIM_AutomaticOutput;
 728:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
 729:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
