1947:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_OC4PolarityConfig(TIM_TypeDef* TIMx, uint16_t TIM_OCPolarity)
1948:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
