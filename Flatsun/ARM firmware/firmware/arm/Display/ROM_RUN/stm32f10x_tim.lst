2461:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Get the Capture 1 Register value */
2462:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   return TIMx->CCR1;
