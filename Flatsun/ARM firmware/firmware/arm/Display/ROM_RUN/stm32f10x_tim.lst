2015:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Reset the CCxNE Bit */
2016:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CCER &= (uint16_t) ~tmp;
2017:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2018:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set or reset the CCxNE Bit */ 
