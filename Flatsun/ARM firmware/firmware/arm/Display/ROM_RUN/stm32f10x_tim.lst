2100:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIMx->CR1 |= TIM_CR1_UDIS;
2101:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
2102:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else
2103:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
2104:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Reset the Update Disable Bit */
2105:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIMx->CR1 &= (uint16_t)~((uint16_t)TIM_CR1_UDIS);
2106:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
2107:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
2108:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2109:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
2110:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Configures the TIMx Update Request Interrupt source.
2111:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be 1 to 17 to select the TIM peripheral.
2112:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_UpdateSource: specifies the Update source.
2113:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be one of the following values:
2114:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_UpdateSource_Regular: Source of update is the counter overflow/underflow
2115:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****                                        or the setting of UG bit, or an update generation
2116:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****                                        through the slave mode controller.
2117:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_UpdateSource_Global: Source of update is counter overflow/underflow.
2118:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
2119:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
2120:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_UpdateRequestConfig(TIM_TypeDef* TIMx, uint16_t TIM_UpdateSource)
2121:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
2122:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
2123:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_ALL_PERIPH(TIMx));
2124:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_UPDATE_SOURCE(TIM_UpdateSource));
2125:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if (TIM_UpdateSource != TIM_UpdateSource_Global)
2126:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
2127:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Set the URS Bit */
2128:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIMx->CR1 |= TIM_CR1_URS;
2129:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
2130:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else
2131:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
2132:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Reset the URS Bit */
2133:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIMx->CR1 &= (uint16_t)~((uint16_t)TIM_CR1_URS);
2134:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
2135:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
2136:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2137:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
2138:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Enables or disables the TIMx's Hall sensor interface.
2139:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be 1, 2, 3, 4, 5 or 8 to select the TIM peripheral.
2140:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  NewState: new state of the TIMx Hall sensor interface.
2141:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be: ENABLE or DISABLE.
2142:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
2143:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
2144:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_SelectHallSensor(TIM_TypeDef* TIMx, FunctionalState NewState)
2145:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
2146:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
