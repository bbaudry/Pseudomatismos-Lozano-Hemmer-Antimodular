2153:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
2154:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else
2155:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
2156:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Reset the TI1S Bit */
2157:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIMx->CR2 &= (uint16_t)~((uint16_t)TIM_CR2_TI1S);
2158:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
2159:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
2160:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2161:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
2162:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Selects the TIMx's One Pulse Mode.
2163:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be 1 to 17 to select the TIM peripheral.
2164:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_OPMode: specifies the OPM Mode to be used.
2165:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be one of the following values:
2166:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_OPMode_Single
2167:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_OPMode_Repetitive
2168:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
2169:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
2170:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_SelectOnePulseMode(TIM_TypeDef* TIMx, uint16_t TIM_OPMode)
2171:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
2172:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
2173:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_ALL_PERIPH(TIMx));
2174:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_OPM_MODE(TIM_OPMode));
2175:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Reset the OPM Bit */
2176:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CR1 &= (uint16_t)~((uint16_t)TIM_CR1_OPM);
2177:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Configure the OPM Mode */
2178:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CR1 |= TIM_OPMode;
2179:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
2180:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2181:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
2182:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Selects the TIMx Trigger Output Mode.
2183:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be 1, 2, 3, 4, 5, 6, 7, 8, 9, 12 or 15 to select the TIM peripheral.
2184:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_TRGOSource: specifies the Trigger Output source.
2185:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This paramter can be one of the following values:
2186:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *
2187:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *  - For all TIMx
2188:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_TRGOSource_Reset:  The UG bit in the TIM_EGR register is used as the trigger outpu
2189:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_TRGOSource_Enable: The Counter Enable CEN is used as the trigger output (TRGO).
2190:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_TRGOSource_Update: The update event is selected as the trigger output (TRGO).
2191:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *
2192:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *  - For all TIMx except TIM6 and TIM7
2193:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_TRGOSource_OC1: The trigger output sends a positive pulse when the CC1IF flag
2194:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *                              is to be set, as soon as a capture or compare match occurs (TRGO).
2195:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_TRGOSource_OC1Ref: OC1REF signal is used as the trigger output (TRGO).
2196:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_TRGOSource_OC2Ref: OC2REF signal is used as the trigger output (TRGO).
2197:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_TRGOSource_OC3Ref: OC3REF signal is used as the trigger output (TRGO).
2198:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_TRGOSource_OC4Ref: OC4REF signal is used as the trigger output (TRGO).
2199:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *
2200:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
2201:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
2202:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_SelectOutputTrigger(TIM_TypeDef* TIMx, uint16_t TIM_TRGOSource)
2203:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
2204:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
2205:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST7_PERIPH(TIMx));
2206:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_TRGO_SOURCE(TIM_TRGOSource));
2207:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Reset the MMS Bits */
2208:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CR2 &= (uint16_t)~((uint16_t)TIM_CR2_MMS);
2209:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Select the TRGO source */
2210:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CR2 |=  TIM_TRGOSource;
2211:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
2212:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2213:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
2214:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Selects the TIMx Slave Mode.
2215:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be 1, 2, 3, 4, 5, 8, 9, 12 or 15 to select the TIM peripheral.
2216:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_SlaveMode: specifies the Timer Slave Mode.
2217:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be one of the following values:
2218:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_SlaveMode_Reset: Rising edge of the selected trigger signal (TRGI) re-initializes
2219:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *                               the counter and triggers an update of the registers.
2220:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_SlaveMode_Gated:     The counter clock is enabled when the trigger signal (TRGI) i
2221:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_SlaveMode_Trigger:   The counter starts at a rising edge of the trigger TRGI.
2222:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_SlaveMode_External1: Rising edges of the selected trigger (TRGI) clock the counter
2223:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
2224:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
2225:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_SelectSlaveMode(TIM_TypeDef* TIMx, uint16_t TIM_SlaveMode)
2226:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
2227:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
2228:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST6_PERIPH(TIMx));
2229:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_SLAVE_MODE(TIM_SlaveMode));
2230:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****  /* Reset the SMS Bits */
2231:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->SMCR &= (uint16_t)~((uint16_t)TIM_SMCR_SMS);
2232:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Select the Slave Mode */
2233:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->SMCR |= TIM_SlaveMode;
2234:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
2235:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2236:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
2237:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Sets or Resets the TIMx Master/Slave Mode.
2238:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be 1, 2, 3, 4, 5, 8, 9, 12 or 15 to select the TIM peripheral.
2239:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_MasterSlaveMode: specifies the Timer Master Slave Mode.
2240:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be one of the following values:
2241:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_MasterSlaveMode_Enable: synchronization between the current timer
2242:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *                                      and its slaves (through TRGO).
2243:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_MasterSlaveMode_Disable: No action
2244:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
2245:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
2246:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_SelectMasterSlaveMode(TIM_TypeDef* TIMx, uint16_t TIM_MasterSlaveMode)
2247:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
2248:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
2249:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST6_PERIPH(TIMx));
2250:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_MSM_STATE(TIM_MasterSlaveMode));
2251:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Reset the MSM Bit */
2252:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->SMCR &= (uint16_t)~((uint16_t)TIM_SMCR_MSM);
2253:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
2254:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set or Reset the MSM Bit */
2255:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->SMCR |= TIM_MasterSlaveMode;
2256:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
2257:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2258:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
