2529:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2530:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
2531:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Checks whether the specified TIM flag is set or not.
2532:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be 1 to 17 to select the TIM peripheral.
2533:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_FLAG: specifies the flag to check.
2534:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be one of the following values:
2535:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_Update: TIM update Flag
2536:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_CC1: TIM Capture Compare 1 Flag
2537:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_CC2: TIM Capture Compare 2 Flag
2538:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_CC3: TIM Capture Compare 3 Flag
2539:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_CC4: TIM Capture Compare 4 Flag
2540:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_COM: TIM Commutation Flag
2541:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_Trigger: TIM Trigger Flag
2542:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_Break: TIM Break Flag
2543:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_CC1OF: TIM Capture Compare 1 overcapture Flag
2544:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_CC2OF: TIM Capture Compare 2 overcapture Flag
2545:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_CC3OF: TIM Capture Compare 3 overcapture Flag
2546:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_CC4OF: TIM Capture Compare 4 overcapture Flag
2547:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @note
2548:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM6 and TIM7 can have only one update flag. 
2549:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM9, TIM12 and TIM15 can have only TIM_FLAG_Update, TIM_FLAG_CC1,
2550:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *      TIM_FLAG_CC2 or TIM_FLAG_Trigger. 
2551:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM10, TIM11, TIM13, TIM14, TIM16 and TIM17 can have TIM_FLAG_Update or TIM_FLAG_CC1.   
2552:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM_FLAG_Break is used only with TIM1, TIM8 and TIM15. 
2553:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM_FLAG_COM is used only with TIM1, TIM8, TIM15, TIM16 and TIM17.    
2554:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval The new state of TIM_FLAG (SET or RESET).
2555:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
2556:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** FlagStatus TIM_GetFlagStatus(TIM_TypeDef* TIMx, uint16_t TIM_FLAG)
2557:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** { 
2558:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   ITStatus bitstatus = RESET;  
2559:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
2560:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_ALL_PERIPH(TIMx));
2561:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_GET_FLAG(TIM_FLAG));
2562:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
2563:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if ((TIMx->SR & TIM_FLAG) != (uint16_t)RESET)
2564:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
2565:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     bitstatus = SET;
2566:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
2567:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else
2568:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
2569:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     bitstatus = RESET;
2570:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
2571:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   return bitstatus;
2572:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
2573:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2574:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
2575:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Clears the TIMx's pending flags.
2576:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be 1 to 17 to select the TIM peripheral.
2577:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_FLAG: specifies the flag bit to clear.
2578:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be any combination of the following values:
2579:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_Update: TIM update Flag
2580:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_CC1: TIM Capture Compare 1 Flag
2581:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_CC2: TIM Capture Compare 2 Flag
2582:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_CC3: TIM Capture Compare 3 Flag
2583:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_CC4: TIM Capture Compare 4 Flag
2584:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_COM: TIM Commutation Flag
2585:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_Trigger: TIM Trigger Flag
2586:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_Break: TIM Break Flag
2587:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_CC1OF: TIM Capture Compare 1 overcapture Flag
2588:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_CC2OF: TIM Capture Compare 2 overcapture Flag
2589:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_CC3OF: TIM Capture Compare 3 overcapture Flag
2590:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_FLAG_CC4OF: TIM Capture Compare 4 overcapture Flag
2591:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @note
2592:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM6 and TIM7 can have only one update flag. 
2593:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM9, TIM12 and TIM15 can have only TIM_FLAG_Update, TIM_FLAG_CC1,
2594:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *      TIM_FLAG_CC2 or TIM_FLAG_Trigger. 
2595:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM10, TIM11, TIM13, TIM14, TIM16 and TIM17 can have TIM_FLAG_Update or TIM_FLAG_CC1.   
2596:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM_FLAG_Break is used only with TIM1, TIM8 and TIM15. 
2597:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM_FLAG_COM is used only with TIM1, TIM8, TIM15, TIM16 and TIM17.   
2598:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
2599:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
2600:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_ClearFlag(TIM_TypeDef* TIMx, uint16_t TIM_FLAG)
2601:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {  
2602:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
2603:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_ALL_PERIPH(TIMx));
2604:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_CLEAR_FLAG(TIM_FLAG));
2605:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****    
2606:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Clear the flags */
2607:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->SR = (uint16_t)~TIM_FLAG;
2608:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
2609:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2610:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
2611:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Checks whether the TIM interrupt has occurred or not.
2612:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be 1 to 17 to select the TIM peripheral.
2613:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_IT: specifies the TIM interrupt source to check.
2614:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be one of the following values:
2615:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_Update: TIM update Interrupt source
2616:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_CC1: TIM Capture Compare 1 Interrupt source
2617:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_CC2: TIM Capture Compare 2 Interrupt source
2618:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_CC3: TIM Capture Compare 3 Interrupt source
2619:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_CC4: TIM Capture Compare 4 Interrupt source
2620:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_COM: TIM Commutation Interrupt source
2621:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_Trigger: TIM Trigger Interrupt source
2622:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_Break: TIM Break Interrupt source
2623:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @note
2624:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM6 and TIM7 can generate only an update interrupt.
2625:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM9, TIM12 and TIM15 can have only TIM_IT_Update, TIM_IT_CC1,
2626:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *      TIM_IT_CC2 or TIM_IT_Trigger. 
2627:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM10, TIM11, TIM13, TIM14, TIM16 and TIM17 can have TIM_IT_Update or TIM_IT_CC1.   
2628:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM_IT_Break is used only with TIM1, TIM8 and TIM15. 
2629:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM_IT_COM is used only with TIM1, TIM8, TIM15, TIM16 and TIM17.  
2630:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval The new state of the TIM_IT(SET or RESET).
2631:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
2632:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** ITStatus TIM_GetITStatus(TIM_TypeDef* TIMx, uint16_t TIM_IT)
2633:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
2634:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   ITStatus bitstatus = RESET;  
2635:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   uint16_t itstatus = 0x0, itenable = 0x0;
2636:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
2637:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_ALL_PERIPH(TIMx));
2638:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_GET_IT(TIM_IT));
2639:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****    
2640:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   itstatus = TIMx->SR & TIM_IT;
2641:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
2642:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   itenable = TIMx->DIER & TIM_IT;
2643:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if ((itstatus != (uint16_t)RESET) && (itenable != (uint16_t)RESET))
2644:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
2645:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     bitstatus = SET;
2646:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
2647:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else
2648:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
2649:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     bitstatus = RESET;
2650:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
2651:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   return bitstatus;
2652:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
2653:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2654:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
2655:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Clears the TIMx's interrupt pending bits.
2656:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be 1 to 17 to select the TIM peripheral.
2657:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_IT: specifies the pending bit to clear.
2658:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be any combination of the following values:
2659:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_Update: TIM1 update Interrupt source
2660:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_CC1: TIM Capture Compare 1 Interrupt source
2661:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_CC2: TIM Capture Compare 2 Interrupt source
2662:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_CC3: TIM Capture Compare 3 Interrupt source
2663:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_CC4: TIM Capture Compare 4 Interrupt source
2664:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_COM: TIM Commutation Interrupt source
2665:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_Trigger: TIM Trigger Interrupt source
2666:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_Break: TIM Break Interrupt source
2667:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @note
2668:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM6 and TIM7 can generate only an update interrupt.
2669:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM9, TIM12 and TIM15 can have only TIM_IT_Update, TIM_IT_CC1,
2670:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *      TIM_IT_CC2 or TIM_IT_Trigger. 
2671:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM10, TIM11, TIM13, TIM14, TIM16 and TIM17 can have TIM_IT_Update or TIM_IT_CC1.   
2672:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM_IT_Break is used only with TIM1, TIM8 and TIM15. 
2673:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM_IT_COM is used only with TIM1, TIM8, TIM15, TIM16 and TIM17.    
2674:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
2675:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
2676:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_ClearITPendingBit(TIM_TypeDef* TIMx, uint16_t TIM_IT)
2677:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
2678:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
2679:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_ALL_PERIPH(TIMx));
2680:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_IT(TIM_IT));
2681:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Clear the IT pending Bit */
2682:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->SR = (uint16_t)~TIM_IT;
2683:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
2684:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
