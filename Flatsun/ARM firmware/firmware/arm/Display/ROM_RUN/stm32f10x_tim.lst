1975:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
1976:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   uint16_t tmp = 0;
1977:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
1978:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
1979:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST8_PERIPH(TIMx));
1980:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_CHANNEL(TIM_Channel));
1981:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_CCX(TIM_CCx));
1982:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
1983:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmp = CCER_CCE_Set << TIM_Channel;
1984:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
1985:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Reset the CCxE Bit */
1986:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CCER &= (uint16_t)~ tmp;
1987:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
1988:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set or reset the CCxE Bit */ 
1989:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CCER |=  (uint16_t)(TIM_CCx << TIM_Channel);
1990:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
