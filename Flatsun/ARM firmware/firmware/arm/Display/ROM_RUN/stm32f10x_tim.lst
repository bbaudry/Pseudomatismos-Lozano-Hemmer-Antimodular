2022:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
2023:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Selects the TIM Output Compare Mode.
2024:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @note   This function disables the selected channel before changing the Output
2025:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *         Compare Mode.
2026:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *         User has to enable this channel using TIM_CCxCmd and TIM_CCxNCmd functions.
2027:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be 1 to 17 except 6 and 7 to select the TIM peripheral.
2028:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_Channel: specifies the TIM Channel
2029:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be one of the following values:
2030:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_Channel_1: TIM Channel 1
2031:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_Channel_2: TIM Channel 2
2032:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_Channel_3: TIM Channel 3
2033:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_Channel_4: TIM Channel 4
2034:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_OCMode: specifies the TIM Output Compare Mode.
2035:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be one of the following values:
2036:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_OCMode_Timing
2037:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_OCMode_Active
2038:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_OCMode_Toggle
2039:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_OCMode_PWM1
2040:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_OCMode_PWM2
2041:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_ForcedAction_Active
2042:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_ForcedAction_InActive
2043:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
2044:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
2045:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_SelectOCxM(TIM_TypeDef* TIMx, uint16_t TIM_Channel, uint16_t TIM_OCMode)
2046:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
2047:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   uint32_t tmp = 0;
2048:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   uint16_t tmp1 = 0;
2049:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2050:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
2051:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST8_PERIPH(TIMx));
2052:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_CHANNEL(TIM_Channel));
2053:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_OCM(TIM_OCMode));
2054:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2055:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmp = (uint32_t) TIMx;
2056:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmp += CCMR_Offset;
2057:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2058:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmp1 = CCER_CCE_Set << (uint16_t)TIM_Channel;
2059:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2060:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Disable the Channel: Reset the CCxE Bit */
2061:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CCER &= (uint16_t) ~tmp1;
2062:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2063:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if((TIM_Channel == TIM_Channel_1) ||(TIM_Channel == TIM_Channel_3))
2064:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
2065:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     tmp += (TIM_Channel>>1);
2066:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2067:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Reset the OCxM bits in the CCMRx register */
2068:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     *(__IO uint32_t *) tmp &= (uint32_t)~((uint32_t)TIM_CCMR1_OC1M);
2069:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****    
2070:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Configure the OCxM bits in the CCMRx register */
2071:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     *(__IO uint32_t *) tmp |= TIM_OCMode;
2072:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
2073:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else
2074:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
2075:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     tmp += (uint16_t)(TIM_Channel - (uint16_t)4)>> (uint16_t)1;
2076:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2077:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Reset the OCxM bits in the CCMRx register */
2078:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     *(__IO uint32_t *) tmp &= (uint32_t)~((uint32_t)TIM_CCMR1_OC2M);
2079:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     
2080:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Configure the OCxM bits in the CCMRx register */
2081:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     *(__IO uint32_t *) tmp |= (uint16_t)(TIM_OCMode << 8);
2082:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
2083:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
2084:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
2085:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
2086:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Enables or Disables the TIMx Update event.
2087:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be 1 to 17 to select the TIM peripheral.
2088:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  NewState: new state of the TIMx UDIS bit
2089:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be: ENABLE or DISABLE.
2090:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
2091:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
2092:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_UpdateDisableConfig(TIM_TypeDef* TIMx, FunctionalState NewState)
2093:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
2094:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
2095:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_ALL_PERIPH(TIMx));
2096:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_FUNCTIONAL_STATE(NewState));
2097:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if (NewState != DISABLE)
2098:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
