2524:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
2525:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_ALL_PERIPH(TIMx));
2526:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Get the Prescaler Register value */
