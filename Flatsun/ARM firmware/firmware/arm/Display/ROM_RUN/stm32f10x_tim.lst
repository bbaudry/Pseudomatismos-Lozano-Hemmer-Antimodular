2148:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_FUNCTIONAL_STATE(NewState));
2149:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if (NewState != DISABLE)
2150:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
2151:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Set the TI1S Bit */
