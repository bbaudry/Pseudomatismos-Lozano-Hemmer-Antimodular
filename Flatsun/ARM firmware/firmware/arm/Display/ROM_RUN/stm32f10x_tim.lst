2264:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_SetCounter(TIM_TypeDef* TIMx, uint16_t Counter)
2265:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
2266:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
2267:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_ALL_PERIPH(TIMx));
2268:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set the Counter Register value */
