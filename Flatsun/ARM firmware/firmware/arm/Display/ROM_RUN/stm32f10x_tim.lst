 186:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }  
 187:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else if (TIMx == TIM13) 
 188:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {       
 189:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     RCC_APB1PeriphResetCmd(RCC_APB1Periph_TIM13, ENABLE);
 190:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     RCC_APB1PeriphResetCmd(RCC_APB1Periph_TIM13, DISABLE);  
 191:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 192:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else if (TIMx == TIM14) 
 193:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {       
 194:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     RCC_APB1PeriphResetCmd(RCC_APB1Periph_TIM14, ENABLE);
 195:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     RCC_APB1PeriphResetCmd(RCC_APB1Periph_TIM14, DISABLE);  
 196:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }        
 197:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else if (TIMx == TIM15)
 198:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 199:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     RCC_APB2PeriphResetCmd(RCC_APB2Periph_TIM15, ENABLE);
 200:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     RCC_APB2PeriphResetCmd(RCC_APB2Periph_TIM15, DISABLE);
 201:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   } 
 202:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else if (TIMx == TIM16)
 203:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 204:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     RCC_APB2PeriphResetCmd(RCC_APB2Periph_TIM16, ENABLE);
 205:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     RCC_APB2PeriphResetCmd(RCC_APB2Periph_TIM16, DISABLE);
 206:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   } 
 207:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else
 208:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 209:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     if (TIMx == TIM17)
 210:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     {
 211:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****       RCC_APB2PeriphResetCmd(RCC_APB2Periph_TIM17, ENABLE);
 212:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****       RCC_APB2PeriphResetCmd(RCC_APB2Periph_TIM17, DISABLE);
 213:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     }  
 214:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 215:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
