1166:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
1167:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Configures the TIMx Prescaler.
1168:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be 1 to 17 to select the TIM peripheral.
1169:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  Prescaler: specifies the Prescaler Register value
1170:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_PSCReloadMode: specifies the TIM Prescaler Reload mode
1171:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be one of the following values:
1172:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_PSCReloadMode_Update: The Prescaler is loaded at the update event.
1173:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_PSCReloadMode_Immediate: The Prescaler is loaded immediately.
1174:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
1175:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
1176:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_PrescalerConfig(TIM_TypeDef* TIMx, uint16_t Prescaler, uint16_t TIM_PSCReloadMode)
1177:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
1178:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
1179:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_ALL_PERIPH(TIMx));
1180:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_PRESCALER_RELOAD(TIM_PSCReloadMode));
1181:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set the Prescaler value */
1182:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->PSC = Prescaler;
1183:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set or reset the UG Bit */
1184:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->EGR = TIM_PSCReloadMode;
1185:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
1186:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
1187:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
1188:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Specifies the TIMx Counter Mode to be used.
1189:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be  1, 2, 3, 4, 5 or 8 to select the TIM peripheral.
1190:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_CounterMode: specifies the Counter Mode to be used
1191:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be one of the following values:
1192:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_CounterMode_Up: TIM Up Counting Mode
1193:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_CounterMode_Down: TIM Down Counting Mode
1194:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_CounterMode_CenterAligned1: TIM Center Aligned Mode1
1195:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_CounterMode_CenterAligned2: TIM Center Aligned Mode2
1196:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_CounterMode_CenterAligned3: TIM Center Aligned Mode3
1197:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
1198:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
1199:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_CounterModeConfig(TIM_TypeDef* TIMx, uint16_t TIM_CounterMode)
1200:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
1201:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   uint16_t tmpcr1 = 0;
1202:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
1203:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST3_PERIPH(TIMx));
1204:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_COUNTER_MODE(TIM_CounterMode));
1205:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpcr1 = TIMx->CR1;
1206:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Reset the CMS and DIR Bits */
1207:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpcr1 &= (uint16_t)(~((uint16_t)(TIM_CR1_DIR | TIM_CR1_CMS)));
1208:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set the Counter Mode */
1209:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpcr1 |= TIM_CounterMode;
1210:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Write to TIMx CR1 register */
1211:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CR1 = tmpcr1;
1212:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
