1761:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST3_PERIPH(TIMx));
1762:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_OCCLEAR_STATE(TIM_OCClear));
1763:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccmr2 = TIMx->CCMR2;
1764:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Reset the OC3CE Bit */
1765:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccmr2 &= (uint16_t)~((uint16_t)TIM_CCMR2_OC3CE);
1766:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Enable or Disable the Output Compare Clear Bit */
1767:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccmr2 |= TIM_OCClear;
1768:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Write to TIMx CCMR2 register */
1769:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CCMR2 = tmpccmr2;
1770:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
