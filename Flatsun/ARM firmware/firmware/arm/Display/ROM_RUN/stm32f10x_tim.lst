1340:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
1341:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   uint16_t tmpccmr1 = 0;
1342:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
1343:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST6_PERIPH(TIMx));
1344:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_FORCED_ACTION(TIM_ForcedAction));
1345:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccmr1 = TIMx->CCMR1;
1346:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Reset the OC2M Bits */
1347:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccmr1 &= (uint16_t)~((uint16_t)TIM_CCMR1_OC2M);
1348:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Configure The Forced output Mode */
1349:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccmr1 |= (uint16_t)(TIM_ForcedAction << 8);
1350:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Write to TIMx CCMR1 register */
1351:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CCMR1 = tmpccmr1;
1352:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
