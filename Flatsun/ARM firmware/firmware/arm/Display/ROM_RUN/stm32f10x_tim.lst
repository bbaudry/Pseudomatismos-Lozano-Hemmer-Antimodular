1161:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpsmcr |= (uint16_t)(TIM_ExtTRGPrescaler | (uint16_t)(TIM_ExtTRGPolarity | (uint16_t)(ExtTRGFilt
1162:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Write to TIMx SMCR */
1163:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->SMCR = tmpsmcr;
1164:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
