 785:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
 786:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
 787:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_BDTRStructInit(TIM_BDTRInitTypeDef* TIM_BDTRInitStruct)
 788:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
 789:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set the default configuration */
 790:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIM_BDTRInitStruct->TIM_OSSRState = TIM_OSSRState_Disable;
 791:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIM_BDTRInitStruct->TIM_OSSIState = TIM_OSSIState_Disable;
 792:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIM_BDTRInitStruct->TIM_LOCKLevel = TIM_LOCKLevel_OFF;
 793:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIM_BDTRInitStruct->TIM_DeadTime = 0x00;
 794:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIM_BDTRInitStruct->TIM_Break = TIM_Break_Disable;
 795:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIM_BDTRInitStruct->TIM_BreakPolarity = TIM_BreakPolarity_Low;
 796:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIM_BDTRInitStruct->TIM_AutomaticOutput = TIM_AutomaticOutput_Disable;
 797:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
 798:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 799:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
 800:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Enables or disables the specified TIM peripheral.
 801:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be 1 to 17 to select the TIMx peripheral.
 802:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  NewState: new state of the TIMx peripheral.
 803:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be: ENABLE or DISABLE.
 804:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
 805:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
 806:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_Cmd(TIM_TypeDef* TIMx, FunctionalState NewState)
 807:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
 808:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
 809:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_ALL_PERIPH(TIMx));
 810:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_FUNCTIONAL_STATE(NewState));
 811:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
 812:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if (NewState != DISABLE)
 813:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 814:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Enable the TIM Counter */
 815:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIMx->CR1 |= TIM_CR1_CEN;
 816:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 817:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else
 818:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 819:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Disable the TIM Counter */
 820:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIMx->CR1 &= (uint16_t)(~((uint16_t)TIM_CR1_CEN));
 821:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 822:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
 823:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 824:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
 825:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Enables or disables the TIM peripheral Main Outputs.
 826:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be 1, 8, 15, 16 or 17 to select the TIMx peripheral.
 827:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  NewState: new state of the TIM peripheral Main Outputs.
 828:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be: ENABLE or DISABLE.
 829:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
 830:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
 831:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_CtrlPWMOutputs(TIM_TypeDef* TIMx, FunctionalState NewState)
 832:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
 833:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
 834:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST2_PERIPH(TIMx));
 835:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_FUNCTIONAL_STATE(NewState));
 836:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if (NewState != DISABLE)
 837:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 838:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Enable the TIM Main Output */
 839:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIMx->BDTR |= TIM_BDTR_MOE;
 840:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 841:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else
 842:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 843:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Disable the TIM Main Output */
 844:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIMx->BDTR &= (uint16_t)(~((uint16_t)TIM_BDTR_MOE));
 845:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }  
 846:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
 847:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 848:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
 849:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Enables or disables the specified TIM interrupts.
 850:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be 1 to 17 to select the TIMx peripheral.
 851:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_IT: specifies the TIM interrupts sources to be enabled or disabled.
 852:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be any combination of the following values:
 853:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_Update: TIM update Interrupt source
 854:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_CC1: TIM Capture Compare 1 Interrupt source
 855:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_CC2: TIM Capture Compare 2 Interrupt source
 856:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_CC3: TIM Capture Compare 3 Interrupt source
 857:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_CC4: TIM Capture Compare 4 Interrupt source
 858:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_COM: TIM Commutation Interrupt source
 859:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_Trigger: TIM Trigger Interrupt source
 860:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_IT_Break: TIM Break Interrupt source
 861:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @note 
 862:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM6 and TIM7 can only generate an update interrupt.
 863:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM9, TIM12 and TIM15 can have only TIM_IT_Update, TIM_IT_CC1,
 864:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *      TIM_IT_CC2 or TIM_IT_Trigger. 
 865:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM10, TIM11, TIM13, TIM14, TIM16 and TIM17 can have TIM_IT_Update or TIM_IT_CC1.   
 866:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM_IT_Break is used only with TIM1, TIM8 and TIM15. 
 867:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM_IT_COM is used only with TIM1, TIM8, TIM15, TIM16 and TIM17.    
 868:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  NewState: new state of the TIM interrupts.
 869:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be: ENABLE or DISABLE.
 870:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
 871:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
 872:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_ITConfig(TIM_TypeDef* TIMx, uint16_t TIM_IT, FunctionalState NewState)
 873:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {  
 874:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
 875:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_ALL_PERIPH(TIMx));
 876:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_IT(TIM_IT));
 877:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_FUNCTIONAL_STATE(NewState));
 878:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
 879:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if (NewState != DISABLE)
 880:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 881:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Enable the Interrupt sources */
 882:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIMx->DIER |= TIM_IT;
 883:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 884:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else
 885:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 886:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Disable the Interrupt sources */
 887:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIMx->DIER &= (uint16_t)~TIM_IT;
 888:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 889:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
 890:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 891:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
 892:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Configures the TIMx event to be generate by software.
 893:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be 1 to 17 to select the TIM peripheral.
 894:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_EventSource: specifies the event source.
 895:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be one or more of the following values:	   
 896:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_EventSource_Update: Timer update Event source
 897:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_EventSource_CC1: Timer Capture Compare 1 Event source
 898:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_EventSource_CC2: Timer Capture Compare 2 Event source
 899:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_EventSource_CC3: Timer Capture Compare 3 Event source
 900:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_EventSource_CC4: Timer Capture Compare 4 Event source
 901:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_EventSource_COM: Timer COM event source  
 902:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_EventSource_Trigger: Timer Trigger Event source
 903:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_EventSource_Break: Timer Break event source
 904:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @note 
 905:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM6 and TIM7 can only generate an update event. 
 906:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   - TIM_EventSource_COM and TIM_EventSource_Break are used only with TIM1 and TIM8.      
 907:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
 908:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
 909:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_GenerateEvent(TIM_TypeDef* TIMx, uint16_t TIM_EventSource)
 910:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** { 
 911:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
 912:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_ALL_PERIPH(TIMx));
 913:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_EVENT_SOURCE(TIM_EventSource));
 914:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
 915:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set the event sources */
 916:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->EGR = TIM_EventSource;
 917:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
 918:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 919:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
 920:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Configures the TIMx's DMA interface.
 921:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be  1, 2, 3, 4, 5, 8, 15, 16 or 17 to select 
 922:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   the TIM peripheral.
 923:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_DMABase: DMA Base address.
 924:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be one of the following values:
 925:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_DMABase_CR, TIM_DMABase_CR2, TIM_DMABase_SMCR,
 926:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *          TIM_DMABase_DIER, TIM1_DMABase_SR, TIM_DMABase_EGR,
 927:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *          TIM_DMABase_CCMR1, TIM_DMABase_CCMR2, TIM_DMABase_CCER,
 928:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *          TIM_DMABase_CNT, TIM_DMABase_PSC, TIM_DMABase_ARR,
 929:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *          TIM_DMABase_RCR, TIM_DMABase_CCR1, TIM_DMABase_CCR2,
 930:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *          TIM_DMABase_CCR3, TIM_DMABase_CCR4, TIM_DMABase_BDTR,
 931:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *          TIM_DMABase_DCR.
 932:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_DMABurstLength: DMA Burst length.
 933:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be one value between:
 934:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   TIM_DMABurstLength_1Transfer and TIM_DMABurstLength_18Transfers.
 935:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
 936:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
 937:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_DMAConfig(TIM_TypeDef* TIMx, uint16_t TIM_DMABase, uint16_t TIM_DMABurstLength)
 938:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
 939:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
 940:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST4_PERIPH(TIMx));
 941:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_DMA_BASE(TIM_DMABase));
 942:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_DMA_LENGTH(TIM_DMABurstLength));
 943:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set the DMA Base and the DMA Burst Length */
 944:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->DCR = TIM_DMABase | TIM_DMABurstLength;
 945:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
 946:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 947:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
 948:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Enables or disables the TIMx's DMA Requests.
 949:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be  1, 2, 3, 4, 5, 6, 7, 8, 15, 16 or 17 
 950:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   to select the TIM peripheral. 
 951:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_DMASource: specifies the DMA Request sources.
 952:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be any combination of the following values:
 953:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_DMA_Update: TIM update Interrupt source
 954:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_DMA_CC1: TIM Capture Compare 1 DMA source
 955:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_DMA_CC2: TIM Capture Compare 2 DMA source
 956:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_DMA_CC3: TIM Capture Compare 3 DMA source
 957:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_DMA_CC4: TIM Capture Compare 4 DMA source
 958:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_DMA_COM: TIM Commutation DMA source
 959:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_DMA_Trigger: TIM Trigger DMA source
 960:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  NewState: new state of the DMA Request sources.
 961:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be: ENABLE or DISABLE.
 962:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
 963:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
 964:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_DMACmd(TIM_TypeDef* TIMx, uint16_t TIM_DMASource, FunctionalState NewState)
 965:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** { 
 966:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
 967:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST9_PERIPH(TIMx));
 968:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_DMA_SOURCE(TIM_DMASource));
 969:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_FUNCTIONAL_STATE(NewState));
 970:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
 971:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if (NewState != DISABLE)
 972:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 973:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Enable the DMA sources */
 974:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIMx->DIER |= TIM_DMASource; 
 975:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 976:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else
 977:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 978:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Disable the DMA sources */
 979:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIMx->DIER &= (uint16_t)~TIM_DMASource;
 980:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 981:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
 982:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 983:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
 984:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Configures the TIMx internal Clock
 985:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be  1, 2, 3, 4, 5, 8, 9, 12 or 15
 986:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *         to select the TIM peripheral.
 987:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
 988:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
 989:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_InternalClockConfig(TIM_TypeDef* TIMx)
 990:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
 991:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
 992:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST6_PERIPH(TIMx));
 993:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Disable slave mode to clock the prescaler directly with the internal clock */
 994:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->SMCR &=  (uint16_t)(~((uint16_t)TIM_SMCR_SMS));
 995:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
 996:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 997:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
 998:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Configures the TIMx Internal Trigger as External Clock
 999:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be  1, 2, 3, 4, 5, 9, 12 or 15 to select the TIM peripheral.
1000:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_ITRSource: Trigger source.
1001:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be one of the following values:
1002:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_TS_ITR0: Internal Trigger 0
1003:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_TS_ITR1: Internal Trigger 1
1004:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_TS_ITR2: Internal Trigger 2
1005:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_TS_ITR3: Internal Trigger 3
1006:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
1007:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
1008:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_ITRxExternalClockConfig(TIM_TypeDef* TIMx, uint16_t TIM_InputTriggerSource)
1009:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
1010:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
1011:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST6_PERIPH(TIMx));
1012:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_INTERNAL_TRIGGER_SELECTION(TIM_InputTriggerSource));
1013:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Select the Internal Trigger */
1014:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIM_SelectInputTrigger(TIMx, TIM_InputTriggerSource);
1015:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Select the External clock mode1 */
1016:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->SMCR |= TIM_SlaveMode_External1;
1017:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
1018:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
1019:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
1020:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Configures the TIMx Trigger as External Clock
1021:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be  1, 2, 3, 4, 5, 9, 12 or 15 to select the TIM peripheral.
1022:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_TIxExternalCLKSource: Trigger source.
1023:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be one of the following values:
1024:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_TIxExternalCLK1Source_TI1ED: TI1 Edge Detector
1025:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_TIxExternalCLK1Source_TI1: Filtered Timer Input 1
1026:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_TIxExternalCLK1Source_TI2: Filtered Timer Input 2
1027:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_ICPolarity: specifies the TIx Polarity.
1028:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be one of the following values:
1029:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_ICPolarity_Rising
1030:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_ICPolarity_Falling
1031:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  ICFilter : specifies the filter value.
1032:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter must be a value between 0x0 and 0xF.
1033:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
1034:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
1035:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_TIxExternalClockConfig(TIM_TypeDef* TIMx, uint16_t TIM_TIxExternalCLKSource,
1036:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****                                 uint16_t TIM_ICPolarity, uint16_t ICFilter)
1037:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
1038:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
1039:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST6_PERIPH(TIMx));
1040:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_TIXCLK_SOURCE(TIM_TIxExternalCLKSource));
1041:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_IC_POLARITY(TIM_ICPolarity));
1042:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_IC_FILTER(ICFilter));
1043:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Configure the Timer Input Clock Source */
1044:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if (TIM_TIxExternalCLKSource == TIM_TIxExternalCLK1Source_TI2)
1045:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
1046:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TI2_Config(TIMx, TIM_ICPolarity, TIM_ICSelection_DirectTI, ICFilter);
1047:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
1048:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   else
1049:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
1050:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TI1_Config(TIMx, TIM_ICPolarity, TIM_ICSelection_DirectTI, ICFilter);
1051:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
1052:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Select the Trigger source */
1053:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIM_SelectInputTrigger(TIMx, TIM_TIxExternalCLKSource);
1054:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Select the External clock mode1 */
1055:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->SMCR |= TIM_SlaveMode_External1;
1056:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
1057:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
1058:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
1059:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Configures the External clock Mode1
1060:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be  1, 2, 3, 4, 5 or 8 to select the TIM peripheral.
1061:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_ExtTRGPrescaler: The external Trigger Prescaler.
1062:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be one of the following values:
1063:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_ExtTRGPSC_OFF: ETRP Prescaler OFF.
1064:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_ExtTRGPSC_DIV2: ETRP frequency divided by 2.
1065:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_ExtTRGPSC_DIV4: ETRP frequency divided by 4.
1066:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_ExtTRGPSC_DIV8: ETRP frequency divided by 8.
1067:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_ExtTRGPolarity: The external Trigger Polarity.
1068:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter can be one of the following values:
1069:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_ExtTRGPolarity_Inverted: active low or falling edge active.
1070:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_ExtTRGPolarity_NonInverted: active high or rising edge active.
1071:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  ExtTRGFilter: External Trigger Filter.
1072:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *   This parameter must be a value between 0x00 and 0x0F
1073:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
1074:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
1075:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_ETRClockMode1Config(TIM_TypeDef* TIMx, uint16_t TIM_ExtTRGPrescaler, uint16_t TIM_ExtTRGPo
1076:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****                              uint16_t ExtTRGFilter)
1077:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
1078:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   uint16_t tmpsmcr = 0;
1079:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
1080:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST3_PERIPH(TIMx));
1081:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_EXT_PRESCALER(TIM_ExtTRGPrescaler));
1082:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_EXT_POLARITY(TIM_ExtTRGPolarity));
1083:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_EXT_FILTER(ExtTRGFilter));
1084:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Configure the ETR Clock source */
1085:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIM_ETRConfig(TIMx, TIM_ExtTRGPrescaler, TIM_ExtTRGPolarity, ExtTRGFilter);
1086:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
1087:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Get the TIMx SMCR register value */
1088:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpsmcr = TIMx->SMCR;
1089:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Reset the SMS Bits */
1090:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpsmcr &= (uint16_t)(~((uint16_t)TIM_SMCR_SMS));
1091:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Select the External clock mode1 */
1092:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpsmcr |= TIM_SlaveMode_External1;
1093:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Select the Trigger selection : ETRF */
1094:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpsmcr &= (uint16_t)(~((uint16_t)TIM_SMCR_TS));
1095:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpsmcr |= TIM_TS_ETRF;
1096:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Write to TIMx SMCR */
1097:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->SMCR = tmpsmcr;
1098:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
1099:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
