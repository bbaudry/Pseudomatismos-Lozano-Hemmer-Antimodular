 217:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
 218:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Initializes the TIMx Time Base Unit peripheral according to 
 219:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *         the specified parameters in the TIM_TimeBaseInitStruct.
 220:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be 1 to 17 to select the TIM peripheral.
 221:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_TimeBaseInitStruct: pointer to a TIM_TimeBaseInitTypeDef
 222:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *         structure that contains the configuration information for the 
 223:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *         specified TIM peripheral.
 224:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
 225:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
 226:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_TimeBaseInit(TIM_TypeDef* TIMx, TIM_TimeBaseInitTypeDef* TIM_TimeBaseInitStruct)
 227:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
 228:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   uint16_t tmpcr1 = 0;
 229:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 230:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
 231:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_ALL_PERIPH(TIMx)); 
 232:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_COUNTER_MODE(TIM_TimeBaseInitStruct->TIM_CounterMode));
 233:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_CKD_DIV(TIM_TimeBaseInitStruct->TIM_ClockDivision));
 234:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 235:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpcr1 = TIMx->CR1;  
 236:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 237:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if((TIMx == TIM1) || (TIMx == TIM8)|| (TIMx == TIM2) || (TIMx == TIM3)||
 238:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****      (TIMx == TIM4) || (TIMx == TIM5)) 
 239:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 240:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Select the Counter Mode */
 241:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     tmpcr1 &= (uint16_t)(~((uint16_t)(TIM_CR1_DIR | TIM_CR1_CMS)));
 242:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     tmpcr1 |= (uint32_t)TIM_TimeBaseInitStruct->TIM_CounterMode;
 243:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 244:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****  
 245:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if((TIMx != TIM6) && (TIMx != TIM7))
 246:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 247:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Set the clock division */
 248:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     tmpcr1 &= (uint16_t)(~((uint16_t)TIM_CR1_CKD));
 249:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     tmpcr1 |= (uint32_t)TIM_TimeBaseInitStruct->TIM_ClockDivision;
 250:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 251:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 252:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CR1 = tmpcr1;
 253:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 254:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set the Autoreload value */
 255:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->ARR = TIM_TimeBaseInitStruct->TIM_Period ;
 256:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****  
 257:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set the Prescaler value */
 258:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->PSC = TIM_TimeBaseInitStruct->TIM_Prescaler;
 259:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     
 260:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if ((TIMx == TIM1) || (TIMx == TIM8)|| (TIMx == TIM15)|| (TIMx == TIM16) || (TIMx == TIM17))  
 261:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 262:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Set the Repetition Counter value */
 263:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     TIMx->RCR = TIM_TimeBaseInitStruct->TIM_RepetitionCounter;
 264:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 265:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 266:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Generate an update event to reload the Prescaler and the Repetition counter
 267:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****      values immediately */
 268:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->EGR = TIM_PSCReloadMode_Immediate;           
 269:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
 270:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 271:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
 272:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Initializes the TIMx Channel1 according to the specified
 273:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *         parameters in the TIM_OCInitStruct.
 274:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be  1 to 17 except 6 and 7 to select the TIM peripheral.
 275:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_OCInitStruct: pointer to a TIM_OCInitTypeDef structure
 276:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *         that contains the configuration information for the specified TIM peripheral.
 277:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
 278:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
 279:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_OC1Init(TIM_TypeDef* TIMx, TIM_OCInitTypeDef* TIM_OCInitStruct)
 280:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
 281:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   uint16_t tmpccmrx = 0, tmpccer = 0, tmpcr2 = 0;
 282:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****    
 283:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
 284:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST8_PERIPH(TIMx));
 285:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_OC_MODE(TIM_OCInitStruct->TIM_OCMode));
 286:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_OUTPUT_STATE(TIM_OCInitStruct->TIM_OutputState));
 287:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_OC_POLARITY(TIM_OCInitStruct->TIM_OCPolarity));   
 288:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****  /* Disable the Channel 1: Reset the CC1E Bit */
 289:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CCER &= (uint16_t)(~(uint16_t)TIM_CCER_CC1E);
 290:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Get the TIMx CCER register value */
 291:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccer = TIMx->CCER;
 292:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Get the TIMx CR2 register value */
 293:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpcr2 =  TIMx->CR2;
 294:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
 295:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Get the TIMx CCMR1 register value */
 296:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccmrx = TIMx->CCMR1;
 297:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     
 298:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Reset the Output Compare Mode Bits */
 299:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccmrx &= (uint16_t)(~((uint16_t)TIM_CCMR1_OC1M));
 300:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccmrx &= (uint16_t)(~((uint16_t)TIM_CCMR1_CC1S));
 301:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 302:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Select the Output Compare Mode */
 303:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccmrx |= TIM_OCInitStruct->TIM_OCMode;
 304:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
 305:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Reset the Output Polarity level */
 306:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccer &= (uint16_t)(~((uint16_t)TIM_CCER_CC1P));
 307:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set the Output Compare Polarity */
 308:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccer |= TIM_OCInitStruct->TIM_OCPolarity;
 309:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
 310:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set the Output State */
 311:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccer |= TIM_OCInitStruct->TIM_OutputState;
 312:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     
 313:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   if((TIMx == TIM1) || (TIMx == TIM8)|| (TIMx == TIM15)||
 314:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****      (TIMx == TIM16)|| (TIMx == TIM17))
 315:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   {
 316:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     assert_param(IS_TIM_OUTPUTN_STATE(TIM_OCInitStruct->TIM_OutputNState));
 317:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     assert_param(IS_TIM_OCN_POLARITY(TIM_OCInitStruct->TIM_OCNPolarity));
 318:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     assert_param(IS_TIM_OCNIDLE_STATE(TIM_OCInitStruct->TIM_OCNIdleState));
 319:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     assert_param(IS_TIM_OCIDLE_STATE(TIM_OCInitStruct->TIM_OCIdleState));
 320:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     
 321:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Reset the Output N Polarity level */
 322:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     tmpccer &= (uint16_t)(~((uint16_t)TIM_CCER_CC1NP));
 323:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Set the Output N Polarity */
 324:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     tmpccer |= TIM_OCInitStruct->TIM_OCNPolarity;
 325:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     
 326:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Reset the Output N State */
 327:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     tmpccer &= (uint16_t)(~((uint16_t)TIM_CCER_CC1NE));    
 328:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Set the Output N State */
 329:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     tmpccer |= TIM_OCInitStruct->TIM_OutputNState;
 330:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     
 331:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Reset the Output Compare and Output Compare N IDLE State */
 332:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     tmpcr2 &= (uint16_t)(~((uint16_t)TIM_CR2_OIS1));
 333:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     tmpcr2 &= (uint16_t)(~((uint16_t)TIM_CR2_OIS1N));
 334:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     
 335:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Set the Output Idle state */
 336:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     tmpcr2 |= TIM_OCInitStruct->TIM_OCIdleState;
 337:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     /* Set the Output N Idle state */
 338:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     tmpcr2 |= TIM_OCInitStruct->TIM_OCNIdleState;
 339:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   }
 340:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Write to TIMx CR2 */
 341:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CR2 = tmpcr2;
 342:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   
 343:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Write to TIMx CCMR1 */
 344:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CCMR1 = tmpccmrx;
 345:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 346:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set the Capture Compare Register value */
 347:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CCR1 = TIM_OCInitStruct->TIM_Pulse; 
 348:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****  
 349:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Write to TIMx CCER */
 350:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CCER = tmpccer;
 351:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
 352:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** 
 353:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** /**
 354:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @brief  Initializes the TIMx Channel2 according to the specified
 355:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *         parameters in the TIM_OCInitStruct.
 356:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIMx: where x can be  1, 2, 3, 4, 5, 8, 9, 12 or 15 to select 
 357:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *         the TIM peripheral.
 358:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @param  TIM_OCInitStruct: pointer to a TIM_OCInitTypeDef structure
 359:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *         that contains the configuration information for the specified TIM peripheral.
 360:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
 361:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
 362:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_OC2Init(TIM_TypeDef* TIMx, TIM_OCInitTypeDef* TIM_OCInitStruct)
 363:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
