1956:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccer |= (uint16_t)(TIM_OCPolarity << 12);
1957:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Write to TIMx CCER register */
