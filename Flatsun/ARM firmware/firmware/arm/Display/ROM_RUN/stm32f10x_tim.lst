1919:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   *     @arg TIM_OCNPolarity_Low: Output Compare active low
1920:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   * @retval None
1921:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   */
1922:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** void TIM_OC3NPolarityConfig(TIM_TypeDef* TIMx, uint16_t TIM_OCNPolarity)
1923:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** {
1924:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   uint16_t tmpccer = 0;
1925:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****  
1926:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Check the parameters */
1927:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_LIST1_PERIPH(TIMx));
1928:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   assert_param(IS_TIM_OCN_POLARITY(TIM_OCNPolarity));
1929:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****     
1930:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccer = TIMx->CCER;
1931:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Set or Reset the CC3NP Bit */
1932:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccer &= (uint16_t)~((uint16_t)TIM_CCER_CC3NP);
1933:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   tmpccer |= (uint16_t)(TIM_OCNPolarity << 8);
1934:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   /* Write to TIMx CCER register */
1935:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c ****   TIMx->CCER = tmpccer;
1936:../Libraries//STM32F10x_StdPeriph_Driver/src/stm32f10x_tim.c **** }
