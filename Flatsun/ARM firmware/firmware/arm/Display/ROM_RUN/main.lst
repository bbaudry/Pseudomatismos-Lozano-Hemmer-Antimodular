 567:main.c        **** /*----------------------------------------------------------------------------
 568:main.c        ****   MAIN function
 569:main.c        ****  *----------------------------------------------------------------------------*/
 570:main.c        **** int main (void) {
 571:main.c        ****     int i, j, k;
 572:main.c        **** 
 573:main.c        ****     unsigned int dot_value = 30;
 574:main.c        ****     char data_active = FALSE;
 575:main.c        **** 
 576:main.c        ****     Init();
 577:main.c        ****     j = k = 0;
 578:main.c        **** 
 579:main.c        ****     GPIOB->ODR = 0;
 580:main.c        **** 
 581:main.c        ****     LED_On(0);
 582:main.c        ****     LED_Off(1);
 583:main.c        ****     LED_On(2);
 584:main.c        **** 
 585:main.c        ****     LEDMode(FALSE);
 586:main.c        **** 
 587:main.c        ****     for (i=0; i<24; i++) {
 588:main.c        ****         SPI_MASTER_Buffer_Tx[i] = 0x00;
 589:main.c        ****     }
 590:main.c        **** 
 591:main.c        ****     DEMUX_Enable(TRUE);
 592:main.c        ****     LEDMode(TRUE);
 593:main.c        ****     SetDotValue(dot_value);
 594:main.c        ****     for (i=0; i<4; i++) {
 595:main.c        ****         UpdateLEDDot();
 596:main.c        ****     }
 597:main.c        ****     BLANK_Set = 0;
 598:main.c        ****     while (BLANK_Set == 0);
 599:main.c        ****     LEDMode(FALSE);
 600:main.c        **** 
 601:main.c        ****     for (i=0; i<PIXEL_COUNT; i++) LEDS[i] = 00;
 602:main.c        **** 
 603:main.c        ****     RS485_Init();
 604:main.c        ****     /* Select the RS485_USART WakeUp Method */
 605:main.c        ****     Address = AddressSelector_Data();
 606:main.c        ****     USART_SetAddress(RS485_USART, Address);
 607:main.c        ****     USART_WakeUpConfig(RS485_USART, USART_WakeUp_AddressMark);
 608:main.c        ****     USART_ReceiverWakeUpCmd(RS485_USART, ENABLE);
 609:main.c        ****     USART_ITConfig(RS485_USART, USART_IT_RXNE, ENABLE);
 610:main.c        ****     
 611:main.c        ****     if (USE_WATCHDOG) {
 612:main.c        ****           IWDG_WriteAccessCmd(IWDG_WriteAccess_Enable);
 613:main.c        ****           IWDG_SetPrescaler(IWDG_Prescaler_128);    /* 3.2 ms per tick */
 614:main.c        ****           IWDG_SetReload(500);                      /* 1.5 seconds timeout */
 615:main.c        ****           IWDG_ReloadCounter();
 616:main.c        ****           /* Enable IWDG (the LSI oscillator will be enabled by hardware) */
 617:main.c        ****           IWDG_Enable();    
 618:main.c        ****     }
 619:main.c        **** 
 620:main.c        ****     j = 0;
 621:main.c        ****     
 622:main.c        ****     // UpdateAnim(0x10);
 623:main.c        ****     
 624:main.c        ****     DrawChar(' ');
 625:main.c        ****     // Loop forever
 626:main.c        ****     while (1) { 
 627:main.c        ****         if (USE_WATCHDOG) {
 628:main.c        ****             IWDG_ReloadCounter();                       // Reset the watchdog timer
 629:main.c        ****         }
 630:main.c        ****         Address = AddressSelector_Data();
 631:main.c        **** 
 632:main.c        ****         // Terminate the RS485 line on panel #0
 633:main.c        ****         if (Address == 0) {
 634:main.c        ****             RS485_PORT->ODR |= ( 1 << 1);           // TE
 635:main.c        ****         } else {
 636:main.c        ****             RS485_PORT->ODR &= ~( 1 << 1);          // ! TE
 637:main.c        ****         }
 638:main.c        **** 
 639:main.c        ****         USART_SetAddress(RS485_USART, Address);
 640:main.c        **** 
 641:main.c        ****         BLANK_Set = 0;
 642:main.c        ****         while (BLANK_Set == 0);
 643:main.c        **** 
 644:main.c        ****         if (CommPacket_Available) {
 645:main.c        ****             if (Packet_CheckCRC(&CommPacket) == TRUE) {
 646:main.c        ****                 if (CommPacket.id != Address) {
 647:main.c        ****                     LED_Toggle(0);
 648:main.c        ****                 } else {
 649:main.c        ****                     data_active = TRUE;
 650:main.c        ****                     memcpy(LEDS, CommPacket.pixels, PIXEL_COUNT);
 651:main.c        ****                     if (dot_value != CommPacket.dot_cor) {
 652:main.c        ****                         dot_value = CommPacket.dot_cor;
 653:main.c        ****                         LEDMode(TRUE);
 654:main.c        ****                         SetDotValue(dot_value);
 655:main.c        ****                         for (i=0; i<4; i++) {
 656:main.c        ****                             UpdateLEDDot();
 657:main.c        ****                         }
 658:main.c        ****                         BLANK_Set = 0;
 659:main.c        ****                         while (BLANK_Set == 0);
 660:main.c        ****                         LEDMode(FALSE);
 661:main.c        ****                     }
 662:main.c        ****                 }
 663:main.c        ****             } else {
 664:main.c        ****                 LED_Toggle(0);
 665:main.c        ****             }
 666:main.c        ****             CommPacket_Available = 0;
 667:main.c        ****         }
 668:main.c        **** 
 669:main.c        ****         if (data_active == FALSE) {
 670:main.c        ****             DrawChar(Address < 10 ? '0' + Address : 'A' + Address - 10);
 671:main.c        ****             LED_Toggle(0);
 672:main.c        ****         }
 673:main.c        **** 
 674:main.c        ****         for (i=0; i<4 ; i++ ) {
 675:main.c        ****             FillBuffer(i, (line + 1 + 16) % 16);
 676:main.c        ****             UpdateLED();
 677:main.c        ****         }
 678:main.c        ****         LED_Toggle(2);
 679:main.c        ****     }
 680:main.c        **** } // end main
